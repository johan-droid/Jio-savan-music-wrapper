# 📄 .env.example
# Port for the Express server (default: 3000)
PORT=3000

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# Optional: Redis connection string for L2 caching
# If not provided, the service will gracefully fall back to L1 (in-memory) caching.
# REDIS_URL=redis://localhost:6379
